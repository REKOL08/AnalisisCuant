    given-names: "Alejandro"
    alias: "REKOL08"
version: 1.0.0
date-released: 2026-07-22
url: "https://rekol08.github.io/AnalisisCuant/"
repository-code: "https://github.com/REKOL08/AnalisisCuant"
license: MIT
keywords:
  - statistics
  - quantitative-analysis
  - academic-research
  - descriptive-statistics
  - hypothesis-testing
  - likert-scale
  - cronbachs-alpha
